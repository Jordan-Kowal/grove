    "@tailwindcss/vite": "4.2.2",
    "daisyui": "5.5.19",
    "rimraf": "6.1.3",
    "solid-devtools": "0.34.5",
    "tailwindcss": "4.2.2",
    "typescript": "6.0.2",
    "vite": "8.0.2",
    "vite-plugin-solid": "2.11.11"
  }
